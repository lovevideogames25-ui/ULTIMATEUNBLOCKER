{
  "name": "GEMMA-3-12B",
  "model": "google/gemma-3-12b-it:free",
  "provider": "OpenRouter",
  "description": "Advanced vision model with enhanced reasoning and superior image understanding",
  "capabilities": [
    "Advanced image analysis",
    "Enhanced visual reasoning",
    "Multimodal processing",
    "Complex text generation",
    "Superior vision-language tasks",
    "High-performance reasoning"
  ],
  "features": {
    "vision_support": true,
    "multimodal": true,
    "enhanced_reasoning": true,
    "image_understanding": true,
    "streaming": true,
    "context_length": "8k",
    "cost_per_token": "Free tier available",
    "specialization": "Advanced vision and multimodal reasoning",
    "parameters": "12B"
