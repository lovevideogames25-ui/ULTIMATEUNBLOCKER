{
  "name": "ultimatelinks",
  "version": "0.5.0-alpha-beta",
  "description": "ULTIMATELINKS - Your Gateway to Unlimited Access",
  "keywords": ["proxy", "games", "movies", "ai-tools", "unblock", "access"],
  "repository": "https://github.com/lovevideogames25-ui/ULTIMATELINKS.git",
  "license": "MIT",
  "author": "alessthegreatestgamer",
  "env": {
    "NODE_ENV": "production",
    "PORT": "3000",
    "NODE_VERSION": "18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "echo 'Static site - no server needed for Glitch'",
    "dev": "echo 'Development mode activated'",
    "build": "echo 'No build process required for static HTML site'"
  },
  "dependencies": {},
  "devDependencies": {
    "serve": "^14.0.0"
  },
  "glitch": {
    "project_type": "static",
    "env": {
      "NODE_ENV": "production",
      "PORT": "3000"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self'"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/home",
      "dest": "/",
      "permanent": true
    },
    {
      "src": "/categories",
      "dest": "/#categories",
      "permanent": true
    },
    {
      "src": "/settings",
      "dest": "/#settings",
      "permanent": true
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
