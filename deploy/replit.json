{
  "name": "ultimatelinks",
  "version": "0.5.0-alpha-beta",
  "description": "ULTIMATELINKS - Your Gateway to Unlimited Access",
  "keywords": ["proxy", "games", "movies", "ai-tools", "unblock", "access"],
  "repository": "https://gitlab.com/alessthegreatestgamer/ultimatelinks.git",
  "license": "MIT",
  "author": "alessthegreatestgamer",
  "main": "index.html",
  "scripts": {
    "start": "echo 'Static site - no server needed for Replit'",
    "dev": "echo 'Development mode activated'",
    "build": "echo 'No build process required for static HTML site'",
    "serve": "npx serve -s . -p 3000",
    "deploy": "echo 'Ready for Replit deployment!'"
  },
  "dependencies": {},
  "devDependencies": {
    "serve": "^14.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "replit": {
    "packageManager": "npm",
    "runOnStart": {
      "command": "echo 'ULTIMATELINKS is running on Replit!'",
      "shell": "bash"
    },
    "ports": {
      "description": "Port for the development server",
      "default": 3000,
      "max": 9999
    },
    "environment": {
      "NODE_ENV": "production",
      "PORT": "3000",
      "NODE_VERSION": "18"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self'"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/home",
      "dest": "/",
      "permanent": true
    },
    {
      "src": "/categories",
      "dest": "/#categories",
      "permanent": true
    },
    {
      "src": "/settings",
      "dest": "/#settings",
      "permanent": true
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
