# ULTIMATEUNBLOCKER Environment Variables Template
# Copy this file to .env and fill in your actual values

# API Keys (Simple Format)
API=your_openrouter_key_here
API2=your_huggingface_key_here
API3=your_lockllm_key_here
API4=your_groq_key_here
API5=your_cloudflare_api_key_here
API6=your_google_ai_studio_key_here
API7=your_github_pat_here
MERRIAM_WEBSTER_API_KEY=your_merriam_webster_api_key_here

# Cloudflare Workers AI
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_GATEWAY_ID=your_cloudflare_gateway_id_here

# Server Configuration

PORT=3000
NODE_ENV=production
DEBUG=false

# Discord Integration
DISCORD_SERVER_ID=1487910769776394343
DISCORD_CHANNEL_ID=1487951675057508444
DISCORD_INVITE_URL=https://discord.gg/PpbddfffVT

# Database (Optional)
DATABASE_URL=mongodb://localhost:27017/ultimateunblocker
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=your_jwt_secret_here_change_this
ENCRYPTION_KEY=your_encryption_key_here_change_this

# Features
ENABLE_AI=true
ENABLE_PROXY=true
ENABLE_CHAT=true
ENABLE_GAMING=true

# Performance
CACHE_TTL=3600
RATE_LIMIT=100
MAX_CONNECTIONS=1000
